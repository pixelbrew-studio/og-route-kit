{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "paths": {
      "@/*": [
        "./*"
      ],
      "og-route-kit": ["../../dist/index.js"],
      "og-route-kit/core": ["../../dist/core/index.js"],
      "og-route-kit/next": ["../../dist/next/index.js"],
      "og-route-kit/examples/cards": ["../../dist/examples/cards/index.js"]
    },
    "noEmit": true,
    "allowJs": true,
    "incremental": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "jsx": "preserve",
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ]
}
