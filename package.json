{
  "name": "og-route-kit",
  "version": "0.0.0",
  "description": "Code-rendered Open Graph image routes for Next.js.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/pixelbrew/og-route-kit#readme",
  "bugs": {
    "url": "https://github.com/pixelbrew/og-route-kit/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/pixelbrew/og-route-kit.git"
  },
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "module": "./dist/index.js",
  "keywords": [
    "opengraph",
    "og-image",
    "nextjs",
    "next-og",
    "image-response",
    "social-image"
  ],
  "bin": {
    "og-route-kit": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./next": {
      "types": "./dist/next/index.d.ts",
      "import": "./dist/next/index.js"
    },
    "./examples/cards": {
      "types": "./dist/examples/cards/index.d.ts",
      "import": "./dist/examples/cards/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "ci": "pnpm typecheck && pnpm test && pnpm build && pnpm example:build && pnpm pack --dry-run",
    "example:build": "pnpm --filter og-route-kit-next-app-example build",
    "lint": "tsc --noEmit",
    "pack:check": "pnpm pack --dry-run",
    "prepack": "pnpm build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify:conductor": "bash scripts/conductor-test.sh"
  },
  "peerDependencies": {
    "next": ">=14.0.0",
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.0.7",
    "@types/react": "^19.1.8",
    "next": "^15.3.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
